{
  "manifest_version": 3,
  "name": "Copy PR Link for Slack",
  "version": "1.2.0",
  "description": "Adds a button to GitHub pull requests that copies a Slack-ready link: an emoji prefix, then the PR title (with number) linked to the PR URL.",
  "browser_specific_settings": {
    "gecko": {
      "id": "copy-pr-link-for-slack@balazsorban.com",
      "strict_min_version": "109.0"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["clipboardWrite", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Copy PR Link for Slack — settings",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*/*/pull/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
